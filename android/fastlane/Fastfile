default_platform(:android)

json_key_file = "service-account-key.json"
topwr_package_name = "com.solvro.topwr"

# Notify Discord on any lane error (CI only, when webhook is configured)
error do |lane, exception|
  if ENV["CI"] == "true" && ENV["DISCORD_WEBHOOK_URL"].to_s.length > 0
    discord_notifier(
      webhook_url: ENV["DISCORD_WEBHOOK_URL"],
      title: "Android Internal Deploy Failed",
      description: exception.message.to_s[0..1000],
      success: false,
      fields: [{ name: "Lane", value: lane.to_s, inline: true }]
    )
  end
end

platform :android do

  desc "Deploy the internal (for testers) version to Google Play"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      json_key: json_key_file,
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      skip_upload_changelogs: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      validate_only: false
    )

    # Discord notification on success (CI only, when webhook is configured)
    if ENV["CI"] == "true" && ENV["DISCORD_WEBHOOK_URL"].to_s.length > 0
      version = ENV["APP_VERSION"] || "—"
      changelog = ENV["LATEST_CHANGELOG"].to_s.gsub('\n', "\n").strip
      changelog = "No changelog available" if changelog.empty?

      discord_notifier(
        webhook_url: ENV["DISCORD_WEBHOOK_URL"],
        title: "Android Internal Deploy",
        description: "New build uploaded to Google Play (Internal).",
        success: true,
        fields: [
          { name: "Version", value: version, inline: true },
          { name: "Track", value: "internal", inline: true },
          { name: "Changelog", value: changelog, inline: false }
        ]
      )
    end
  end
end
