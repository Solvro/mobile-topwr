# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

# Notify Discord on any lane error (CI only, when webhook is configured)
error do |lane, exception|
  if ENV["CI"] == "true" && ENV["DISCORD_WEBHOOK_URL"].to_s.length > 0
    discord_notifier(
      webhook_url: ENV["DISCORD_WEBHOOK_URL"],
      title: "iOS Internal Deploy Failed",
      description: exception.message.to_s[0..1000],
      success: false,
      fields: [{ name: "Lane", value: lane.to_s, inline: true }]
    )
  end
end

platform :ios do
  desc "Push a new intenal build to TestFlight for internal testers"
  lane :internal do
    setup_ci if ENV["CI"]

    # Use App Store Connect API Key in CI
    api_key = nil
    if ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"] && ENV["APP_STORE_CONNECT_API_KEY_KEY_PATH"]
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
        key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_PATH"]
      )
    end

    match(type: "appstore", readonly: true, api_key: api_key)
    build_app(
      workspace: "./Runner.xcworkspace",
      scheme: "Runner"
    )
    upload_options = {
      distribute_external: false,
      notify_external_testers: false,
      submit_beta_review: false
    }
    upload_options[:api_key] = api_key if api_key
    upload_to_testflight(upload_options)

    # Discord notification on success (CI only, when webhook is configured)
    if ENV["CI"] == "true" && ENV["DISCORD_WEBHOOK_URL"].to_s.length > 0
      version = ENV["APP_VERSION"] || "—"
      changelog = ENV["LATEST_CHANGELOG"].to_s.gsub('\n', "\n").strip
      changelog = "No changelog available" if changelog.empty?

      discord_notifier(
        webhook_url: ENV["DISCORD_WEBHOOK_URL"],
        title: "iOS Internal Deploy",
        description: "New build uploaded to TestFlight (Internal).",
        success: true,
        fields: [
          { name: "Version", value: version, inline: true },
          { name: "Group", value: "Internal", inline: true },
          { name: "Changelog", value: changelog, inline: false }
        ]
      )
    end
  end
end
